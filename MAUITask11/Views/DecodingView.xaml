<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MAUITask11.DecodingView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MAUITask11.ViewModels"
    x:DataType="vm:DecodingViewModel"
    Title="PESEL Decoding">

    <Grid RowDefinitions="*, Auto" Padding="16">

        <!-- RESULTS AREA (hidden until Decoded = true) -->
        <ScrollView Grid.Row="0" IsVisible="{Binding Decoded}">
            <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                <!-- Left column: data labels -->
                <VerticalStackLayout Grid.Column="0" Spacing="12">

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Gender:" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="{Binding Gender}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Birth date:" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="{Binding BirthDate}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Age:" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="{Binding Age}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Days till birthday:" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="{Binding NextBirthdayDays}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="8" Margin="0,8,0,0" VerticalOptions="Center">
                        <Label
                            Text="{Binding ValiditySymbol}"
                            TextColor="{Binding ValidityColor}"
                            FontSize="26"
                            FontAttributes="Bold"
                            VerticalOptions="Center"/>
                        <Label
                            Text="{Binding ValidityText}"
                            FontAttributes="Bold"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="1"
                    VerticalOptions="Center"
                    HorizontalOptions="Center">
                    <Label
                        Text="{Binding GenderSymbol}"
                        TextColor="{Binding GenderColor}"
                        FontSize="288"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="8" Margin="0,12,0,0">
            <Entry
                Grid.Column="0"
                Placeholder="Enter PESEL:"
                Text="{Binding Pesel}"
                Keyboard="Numeric"
                MaxLength="11"
                VerticalOptions="Center"/>
            <Button
                Grid.Column="1"
                Text="Decode"
                Command="{Binding DecodePeselCommand}"
                VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
