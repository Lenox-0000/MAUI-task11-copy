<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MAUITask11.EncodingView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:vm="clr-namespace:MAUITask11.ViewModels"
    x:DataType="vm:EncodingViewModel"
    Title="Pesel Encoding">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="16">

            <Label Text="Birth day:" FontAttributes="Bold" />
            <DatePicker
                Format="dd.MM.yyyy"
                MaximumDate="{x:Static sys:DateTime.Today}"
                Date="{Binding BirthDay}" />

            <Label Text="Gender:" FontAttributes="Bold" />
            <Picker
                Title="Select gender"
                ItemDisplayBinding="{Binding Name}"
                ItemsSource="{Binding Genders}"
                SelectedItem="{Binding SelectedGender}" />

            <HorizontalStackLayout Spacing="10">
                <Button
                    Text="Generate PESEL"
                    Command="{Binding GeneratePeselCommand}" />
                <Button
                    Text="Copy to clipboard"
                    Command="{Binding CopyToClipboardCommand}" />
            </HorizontalStackLayout>

            <Border
                IsVisible="{Binding IsGenerated}"
                Padding="16"
                BackgroundColor="{AppThemeBinding Light=#F0F4FF, Dark=#1E2A3A}"
                Stroke="{AppThemeBinding Light=#7B8FC7, Dark=#4A5C8A}"
                StrokeThickness="1.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label
                        Text="Generated PESEL:"
                        FontAttributes="Bold"
                        HorizontalOptions="Center" />
                    <Label
                        Text="{Binding GeneratedPesel}"
                        FontSize="24"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        CharacterSpacing="3" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
